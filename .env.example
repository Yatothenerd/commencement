# Copy this file to .env.local and paste your Neon connection string.
# NEVER commit the real value. Set the same variable in your host's
# dashboard (Vercel/Netlify) as DATABASE_URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Optional: protect write operations (add/edit/delete) on /api/guests.
# If set, the admin page will ask for this token once and remember it
# for the session. Leave unset to allow writes without a token.
ADMIN_TOKEN=choose-a-long-random-string
